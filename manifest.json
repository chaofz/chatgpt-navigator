{
  "manifest_version": 3,
  "name": "Navigator for ChatGPT",
  "version": "1.0.0",
  "description": "Enhance your ChatGPT experience with a navigation sidebar supporting automatic outline, and scroll pin and lock.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "action": {},
  "background": {
    "service_worker": "background.js"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}